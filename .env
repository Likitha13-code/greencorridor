# ============================================================
#  GreenCorridor — Environment Configuration
#  Single-file frontend app (code.html)
#
#  NOTE: This file is for documentation and future backend
#  integration. A plain HTML file cannot read .env directly.
#  If you add a build step (Vite, Webpack, Node.js) these
#  values should be injected at build time or served via API.
# ============================================================


# ── Map Tile Layer ──────────────────────────────────────────
# CartoDB Dark Matter tiles (free, no API key required)
MAP_TILE_URL=https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png
MAP_TILE_ATTRIBUTION=© OpenStreetMap contributors © CARTO
MAP_MAX_ZOOM=19
MAP_DEFAULT_ZOOM=14


# ── Geocoding API (Nominatim / OpenStreetMap) ───────────────
# Free public API — no key required
# Rate limit: 1 request/second. For production use a
# self-hosted Nominatim instance or a paid geocoding service.
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_SEARCH_LIMIT=8
NOMINATIM_UNIT_SEARCH_LIMIT=4
NOMINATIM_LANGUAGE=en

# City context appended to every search query
SEARCH_CITY=Bangalore

# Bangalore bounding box for bounded Nominatim queries
# Format: left,top,right,bottom (lng/lat)
BLR_VIEWBOX=77.4,13.2,77.85,12.78


# ── Routing API (OSRM) ──────────────────────────────────────
# Free public OSRM demo server — no key required
# For production use a self-hosted OSRM instance
OSRM_BASE_URL=https://router.project-osrm.org
OSRM_PROFILE=driving
OSRM_ALTERNATIVES=3


# ── CDN Libraries ───────────────────────────────────────────
LEAFLET_VERSION=1.9.4
LEAFLET_CSS_CDN=https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css
LEAFLET_JS_CDN=https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js
TURF_CDN=https://unpkg.com/@turf/turf@6/turf.min.js


# ── Ambulance Simulation ────────────────────────────────────
# Base movement speed in km/h (applies to all ambulances)
AMB_BASE_SPEED_KMH=5

# Speed multiplier when approaching a signal (braking zone)
AMB_APPROACH_SPEED_MULT=0.35

# Speed multiplier when stopped at a signal
AMB_SIGNAL_STOP_MULT=0.10

# How long the ambulance pauses at each signal (milliseconds)
AMB_SIGNAL_PAUSE_MS=1800


# ── Geofence Radii (km) ─────────────────────────────────────
# Ring 1 — awareness zone: pre-compute corridor
GEO_RADIUS_OUTER_KM=2.0

# Ring 2 — approach zone: start cross-traffic countdown
GEO_RADIUS_MID_KM=1.0

# Ring 3 — preemption zone: force green immediately
GEO_RADIUS_INNER_KM=0.5

# Cross-traffic hold countdown when ambulance enters mid ring
CROSS_TRAFFIC_TIMER_SECONDS=28


# ── Conflict Detection (Multi-Ambulance) ────────────────────
# Two units must be within this distance (km) of a shared
# signal for a conflict to be registered
CONFLICT_DETECTION_RANGE_KM=0.6

# How often the conflict arbitration loop runs (milliseconds)
CONFLICT_CHECK_INTERVAL_MS=1000

# Priority formula: score = (severity × SEVERITY_WEIGHT) − eta_seconds
PRIORITY_SEVERITY_WEIGHT=1000


# ── Fleet ───────────────────────────────────────────────────
# Comma-separated hex colours assigned to fleet units in order
FLEET_COLORS=#3fb950,#58a6ff,#bc8cff,#e3b341

# Maximum number of simultaneous fleet units (including primary)
FLEET_MAX_UNITS=4


# ── UI Timings ──────────────────────────────────────────────
# Signal list refresh interval (milliseconds)
SIGNAL_LIST_REFRESH_MS=500

# Fleet panel refresh interval (milliseconds)
FLEET_PANEL_REFRESH_MS=2000

# Live DB panel refresh interval (milliseconds)
DB_PANEL_REFRESH_MS=500

# Map popup display duration (milliseconds)
POPUP_DURATION_MS=3500


# ── Firebase Realtime Database ──────────────────────────────
FIREBASE_API_KEY=AIzaSyAODSwadIPqPqoZn4C_yb6Xo_fByIhAkv8
FIREBASE_AUTH_DOMAIN=greencorridor-bf773.firebaseapp.com
FIREBASE_DATABASE_URL=https://greencorridor-bf773-default-rtdb.asia-southeast1.firebasedatabase.app
FIREBASE_PROJECT_ID=greencorridor-bf773
FIREBASE_STORAGE_BUCKET=greencorridor-bf773.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=129832118137
FIREBASE_APP_ID=1:129832118137:web:b6a1ee7888d420a3bfb1a8
FIREBASE_MEASUREMENT_ID=G-WZJX805J15

# Firebase write throttle for live-state tables (milliseconds)
FIREBASE_THROTTLE_MS=5000


# ── App Meta ────────────────────────────────────────────────
APP_NAME=GreenCorridor
APP_VERSION=1.0.0
APP_ENV=development
